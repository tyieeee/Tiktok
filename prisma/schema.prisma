// CollabTik - Prisma schema
// PostgreSQL via Supabase or Neon

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------
enum Role {
  CREATOR
  BRAND
  ADMIN
}

enum CompensationType {
  FIXED
  REVENUE
  PRODUCT
}

enum CampaignStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum CollaborationStatus {
  CONTRACT_PENDING
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum DeliverableType {
  VIDEO
  STORY
  LIVE
}

enum DeliverableStatus {
  PENDING
  SUBMITTED
  REVISION_REQUESTED
  APPROVED
}

enum PaymentStatus {
  HELD
  RELEASED
  REFUNDED
}

enum ReviewRole {
  CREATOR_TO_BRAND
  BRAND_TO_CREATOR
}

enum NotificationType {
  APPLICATION_NEW
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  DELIVERABLE_SUBMITTED
  DELIVERABLE_APPROVED
  DELIVERABLE_REVISION
  MESSAGE_RECEIVED
  PAYMENT_RELEASED
  CAMPAIGN_UPDATE
}

// ---------- Auth.js required tables ----------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Core models ----------
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  passwordHash   String?
  name           String?
  avatar         String?
  role           Role      @default(CREATOR)
  onboardedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  creatorProfile        CreatorProfile?
  brandProfile          BrandProfile?
  sentMessages          Message[]              @relation("SentMessages")
  notifications         Notification[]
  reviewsGiven          Review[]               @relation("Reviewer")
  reviewsReceived       Review[]               @relation("Reviewee")
  stripeCustomerId      String?
  stripeConnectAccountId String?

  @@index([role])
}

model CreatorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?  @db.Text
  niche           String[]
  categories      String[]
  tikTokHandle    String?  @unique
  tikTokVerified  Boolean  @default(false)
  followerCount   Int      @default(0)
  engagementRate  Float    @default(0)
  avgViews        Int      @default(0)
  location        String?
  languages       String[]
  portfolioMedia  String[]
  pricePerPost    Int      @default(0) // cents
  applications    Application[]
  analytics       AnalyticsSnapshot[]

  @@index([tikTokHandle])
  @@index([followerCount])
}

model BrandProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  website      String?
  industry     String?
  description  String?   @db.Text
  logo         String?
  verified     Boolean   @default(false)
  campaigns    Campaign[]

  @@index([companyName])
}

model Campaign {
  id               String           @id @default(cuid())
  brandId          String
  brand            BrandProfile     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  title            String
  description      String           @db.Text
  brief            String           @db.Text
  briefAttachments String[]
  requirements     Json
  budget           Int              // cents
  compensationType CompensationType @default(FIXED)
  deadline         DateTime
  status           CampaignStatus   @default(DRAFT)
  targetNiche      String[]
  location         String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  applications     Application[]
  messages         Message[]

  @@index([brandId])
  @@index([status])
  @@index([deadline])
}

model Application {
  id             String            @id @default(cuid())
  campaignId     String
  campaign       Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatorId      String
  creator        CreatorProfile    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  coverLetter    String            @db.Text
  proposedPrice  Int               // cents
  matchScore     Float             @default(0)
  status         ApplicationStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  collaboration  Collaboration?

  @@unique([campaignId, creatorId])
  @@index([campaignId])
  @@index([creatorId])
  @@index([status])
}

model Collaboration {
  id            String              @id @default(cuid())
  applicationId String              @unique
  application   Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  status        CollaborationStatus @default(CONTRACT_PENDING)
  contractUrl   String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  deliverables  Deliverable[]
  payments      Payment[]
  messages      Message[]

  @@index([status])
}

model Deliverable {
  id                   String            @id @default(cuid())
  collaborationId      String
  collaboration        Collaboration     @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  type                 DeliverableType   @default(VIDEO)
  dueDate              DateTime
  contentUrl           String?
  tikTokVideoUrl       String?
  captionRequirements  String?           @db.Text
  hashtags             String[]
  status               DeliverableStatus @default(PENDING)
  feedback             String?           @db.Text
  revisionCount        Int               @default(0)
  submittedAt          DateTime?
  approvedAt           DateTime?
  metricsViews         Int?
  metricsLikes         Int?
  metricsShares        Int?
  metricsComments      Int?
  metricsFetchedAt     DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([collaborationId])
  @@index([status])
  @@index([dueDate])
}

model Payment {
  id                    String        @id @default(cuid())
  collaborationId       String
  collaboration         Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  amount                Int           // cents, net to creator
  platformFee           Int           // cents
  status                PaymentStatus @default(HELD)
  stripePaymentIntentId String?       @unique
  stripeTransferId      String?
  releasedAt            DateTime?
  refundedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([collaborationId])
  @@index([status])
}

model Message {
  id              String        @id @default(cuid())
  collaborationId String?
  collaboration   Collaboration? @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  campaignId      String?
  campaign        Campaign?     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content         String        @db.Text
  attachments     String[]
  readAt          DateTime?
  createdAt       DateTime      @default(now())

  @@index([collaborationId])
  @@index([campaignId])
  @@index([senderId])
  @@index([createdAt])
}

model AnalyticsSnapshot {
  id             String   @id @default(cuid())
  creatorId      String
  creator        CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  date           DateTime
  followers      Int
  totalLikes     Int
  totalViews     Int
  engagementRate Float

  @@unique([creatorId, date])
  @@index([creatorId])
  @@index([date])
}

model Review {
  id              String        @id @default(cuid())
  reviewerId      String
  reviewer        User          @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId      String
  reviewee        User          @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
  collaborationId String
  rating          Int           // 1-5
  comment         String?       @db.Text
  role            ReviewRole
  createdAt       DateTime      @default(now())

  @@unique([reviewerId, collaborationId])
  @@index([revieweeId])
  @@index([collaborationId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
}
